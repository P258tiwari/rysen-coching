<%- include('partials/head') %>
<%- include('partials/nav') %>

<main>

  <!-- HERO -->
  <section class="pt-32 pb-16 lg:pt-40 lg:pb-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl fade-in">
        <p class="text-xs font-semibold tracking-widest uppercase text-gold mb-6">Get in Touch</p>
        <h1 class="font-serif text-5xl lg:text-6xl font-bold text-text-primary leading-tight mb-8">Let's build something that lasts.</h1>
        <p class="text-text-muted text-lg leading-relaxed">
          Ready to take the next step in your leadership journey? Let's connect.
        </p>
      </div>
    </div>
  </section>

  <!-- GOLD RULE -->
  <div class="max-w-7xl mx-auto px-6 lg:px-8"><div class="gold-rule"></div></div>

  <!-- TWO COLUMN: Contact Info + Form -->
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">

        <!-- Left: Contact Info -->
        <div class="lg:col-span-4 fade-in">
          <div class="space-y-10">

            <div>
              <p class="text-xs font-semibold tracking-widest uppercase text-gold mb-5">Book Directly</p>
              <p class="text-sm text-text-muted mb-4 leading-relaxed">Schedule a Discovery Session on Topmate — the fastest way to get started.</p>
              <a href="https://topmate.io/bidisha_banerjee" target="_blank" rel="noopener noreferrer"
                class="inline-block px-6 py-3 bg-text-primary text-white text-sm font-semibold tracking-wide hover:bg-gold transition-colors duration-300">
                Visit Topmate
              </a>
            </div>

            <div class="w-full h-px bg-border"></div>

            <div>
              <p class="text-xs font-semibold tracking-widest uppercase text-gold mb-5">Reach Out</p>
              <div class="space-y-4">
                <div class="flex items-start gap-3">
                  <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                  <div>
                    <p class="text-xs text-text-muted mb-1">Email</p>
                    <a href="mailto:bidisha@rysencoaching.com" class="text-sm text-text-primary hover:text-gold transition-colors font-medium">bidisha@rysencoaching.com</a>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  <div>
                    <p class="text-xs text-text-muted mb-1">LinkedIn</p>
                    <a href="https://www.linkedin.com/in/bidisha-banerjee" target="_blank" rel="noopener noreferrer" class="text-sm text-text-primary hover:text-gold transition-colors font-medium">linkedin.com/in/bidisha-banerjee</a>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-4 h-4 text-gold mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                  <div>
                    <p class="text-xs text-text-muted mb-1">Instagram</p>
                    <a href="https://www.instagram.com/coach_author_bidishabanerjee" target="_blank" rel="noopener noreferrer" class="text-sm text-text-primary hover:text-gold transition-colors font-medium">@coach_author_bidishabanerjee</a>
                  </div>
                </div>
              </div>
            </div>

            <div class="w-full h-px bg-border"></div>

            <div>
              <p class="text-xs font-semibold tracking-widest uppercase text-gold mb-3">Response Time</p>
              <p class="text-sm text-text-muted leading-relaxed">I typically respond within 24&#8211;48 hours. For speaking and organisational enquiries, please include as much context as possible.</p>
            </div>

          </div>
        </div>

        <!-- Right: Contact Form -->
        <div class="lg:col-span-8 fade-in">
          <div class="border border-border p-8 lg:p-12">
            <p class="text-xs font-semibold tracking-widest uppercase text-gold mb-8">Send a Message</p>

            <form id="contact-form" class="space-y-6">
              <!-- Honeypot — hidden from real users, bots will fill this in -->
              <div style="position:absolute;left:-9999px;height:0;width:0;overflow:hidden;" aria-hidden="true">
                <label for="company_website">Company Website</label>
                <input type="text" id="company_website" name="company_website" tabindex="-1" autocomplete="off">
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-xs font-semibold tracking-widest uppercase text-text-muted mb-2">Name <span class="text-gold">*</span></label>
                  <input type="text" id="name" name="name" required autocomplete="name"
                    class="w-full px-4 py-3.5 border border-border bg-transparent text-text-primary text-sm placeholder-gray-400 focus:outline-none focus:border-gold transition-colors duration-300"
                    placeholder="Your full name">
                </div>
                <div>
                  <label for="email" class="block text-xs font-semibold tracking-widest uppercase text-text-muted mb-2">Email <span class="text-gold">*</span></label>
                  <input type="email" id="email" name="email" required autocomplete="email"
                    class="w-full px-4 py-3.5 border border-border bg-transparent text-text-primary text-sm placeholder-gray-400 focus:outline-none focus:border-gold transition-colors duration-300"
                    placeholder="your@email.com">
                </div>
              </div>

              <div>
                <label for="linkedin" class="block text-xs font-semibold tracking-widest uppercase text-text-muted mb-2">LinkedIn Profile <span class="text-text-muted font-normal normal-case tracking-normal">(optional)</span></label>
                <input type="url" id="linkedin" name="linkedin" autocomplete="url"
                  class="w-full px-4 py-3.5 border border-border bg-transparent text-text-primary text-sm placeholder-gray-400 focus:outline-none focus:border-gold transition-colors duration-300"
                  placeholder="https://linkedin.com/in/yourname">
              </div>

              <div>
                <label for="message" class="block text-xs font-semibold tracking-widest uppercase text-text-muted mb-2">Message / Current Transition <span class="text-gold">*</span></label>
                <textarea id="message" name="message" required rows="6"
                  class="w-full px-4 py-3.5 border border-border bg-transparent text-text-primary text-sm placeholder-gray-400 focus:outline-none focus:border-gold transition-colors duration-300 resize-none"
                  placeholder="Tell me a little about where you are and what you're navigating. The more context you share, the more I can help."></textarea>
              </div>

              <div>
                <button type="submit" id="submit-btn"
                  class="w-full sm:w-auto px-10 py-4 bg-text-primary text-white text-sm font-semibold tracking-wide hover:bg-gold transition-colors duration-300 flex items-center gap-3">
                  <span id="btn-text">Send Message</span>
                  <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                </button>
              </div>

              <!-- Success/Error messages -->
              <div id="form-success" class="hidden flex items-start gap-3 p-4 bg-green-50 border border-green-200">
                <svg class="w-5 h-5 text-green-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <div>
                  <p class="text-sm font-semibold text-green-800">Message sent.</p>
                  <p class="text-sm text-green-700 mt-1">Thank you! I'll get back to you within 24&#8211;48 hours.</p>
                </div>
              </div>

              <div id="form-error" class="hidden flex items-start gap-3 p-4 bg-red-50 border border-red-200">
                <svg class="w-5 h-5 text-red-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p id="form-error-text" class="text-sm text-red-700"></p>
              </div>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- GOLD RULE -->
  <div class="max-w-7xl mx-auto px-6 lg:px-8"><div class="gold-rule"></div></div>

  <!-- FAQ ACCORDION -->
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
        <div class="lg:col-span-4 fade-in">
          <p class="text-xs font-semibold tracking-widest uppercase text-gold mb-4">FAQ</p>
          <h2 class="font-serif text-4xl font-bold text-text-primary leading-tight">Common questions</h2>
        </div>

        <div class="lg:col-span-8 fade-in">
          <div id="faq" class="space-y-0">

            <div class="faq-item border-b border-border">
              <button class="faq-trigger w-full flex items-center justify-between py-6 text-left group">
                <span class="text-sm font-semibold text-text-primary group-hover:text-gold transition-colors pr-8">How do I get started?</span>
                <span class="faq-icon text-gold flex-shrink-0 transition-transform duration-300">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                </span>
              </button>
              <div class="faq-content hidden pb-6">
                <p class="text-sm text-text-muted leading-relaxed">The best starting point is a Discovery Session — a 60-minute coaching conversation to understand exactly where you are and what's possible. You can book directly at <a href="https://topmate.io/bidisha_banerjee" target="_blank" rel="noopener noreferrer" class="text-gold hover:underline">Topmate</a>, or send me a message using the form on this page.</p>
              </div>
            </div>

            <div class="faq-item border-b border-border">
              <button class="faq-trigger w-full flex items-center justify-between py-6 text-left group">
                <span class="text-sm font-semibold text-text-primary group-hover:text-gold transition-colors pr-8">What if I'm not sure which program suits me?</span>
                <span class="faq-icon text-gold flex-shrink-0 transition-transform duration-300">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                </span>
              </button>
              <div class="faq-content hidden pb-6">
                <p class="text-sm text-text-muted leading-relaxed">That's exactly what the Discovery Session is for. We identify where you are, what you're navigating, and what level of support will create the most impact. The ₹12,000 Discovery fee is fully redeemable against any programme you choose to proceed with.</p>
              </div>
            </div>

            <div class="faq-item border-b border-border">
              <button class="faq-trigger w-full flex items-center justify-between py-6 text-left group">
                <span class="text-sm font-semibold text-text-primary group-hover:text-gold transition-colors pr-8">How long does coaching take?</span>
                <span class="faq-icon text-gold flex-shrink-0 transition-transform duration-300">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                </span>
              </button>
              <div class="faq-content hidden pb-6">
                <p class="text-sm text-text-muted leading-relaxed">It depends on the programme and your goals. The Clarity Sprint runs 4&#8211;5 weeks. The Breakthrough Programme takes 8&#8211;10 weeks. The flagship Rise to Your Next Level is a 3-month journey. Most clients begin noticing meaningful shifts in the first two or three sessions.</p>
              </div>
            </div>

            <div class="faq-item border-b border-border">
              <button class="faq-trigger w-full flex items-center justify-between py-6 text-left group">
                <span class="text-sm font-semibold text-text-primary group-hover:text-gold transition-colors pr-8">Online or in-person?</span>
                <span class="faq-icon text-gold flex-shrink-0 transition-transform duration-300">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                </span>
              </button>
              <div class="faq-content hidden pb-6">
                <p class="text-sm text-text-muted leading-relaxed">All individual coaching sessions are conducted online via video call, which allows us to work together regardless of your location. Organisational programmes and speaking engagements can be in-person across India and internationally.</p>
              </div>
            </div>

            <div class="faq-item border-b border-border">
              <button class="faq-trigger w-full flex items-center justify-between py-6 text-left group">
                <span class="text-sm font-semibold text-text-primary group-hover:text-gold transition-colors pr-8">What's your coaching approach?</span>
                <span class="faq-icon text-gold flex-shrink-0 transition-transform duration-300">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                </span>
              </button>
              <div class="faq-content hidden pb-6">
                <p class="text-sm text-text-muted leading-relaxed">My approach is empathetic yet challenging, insight-driven yet practical, reflective yet outcome-focused. I ask the questions that create real clarity — not comfortable ones. I draw on 25+ years of experience in organisational leadership, so I understand what actually happens in the room and what boards and organisations look for.</p>
              </div>
            </div>

            <div class="faq-item">
              <button class="faq-trigger w-full flex items-center justify-between py-6 text-left group">
                <span class="text-sm font-semibold text-text-primary group-hover:text-gold transition-colors pr-8">Do you offer organisational coaching?</span>
                <span class="faq-icon text-gold flex-shrink-0 transition-transform duration-300">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                </span>
              </button>
              <div class="faq-content hidden pb-6">
                <p class="text-sm text-text-muted leading-relaxed">Yes. I work with organisations through bespoke leadership transformation programmes, culture and behavioural alignment interventions, and women &amp; inclusive leadership initiatives. I've partnered with organisations like Google, PayPal, DHL, and IKEA. Please use the contact form to describe your needs and I'll respond with a tailored proposal.</p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

</main>

<script>
  // Contact form
  document.getElementById('contact-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const btn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');
    const btnSpinner = document.getElementById('btn-spinner');
    const successEl = document.getElementById('form-success');
    const errorEl = document.getElementById('form-error');
    const errorText = document.getElementById('form-error-text');

    btn.disabled = true;
    btnText.textContent = 'Sending...';
    btnSpinner.classList.remove('hidden');
    successEl.classList.add('hidden');
    errorEl.classList.add('hidden');

    const data = {
      name: form.name.value.trim(),
      email: form.email.value.trim(),
      linkedin: form.linkedin.value.trim(),
      message: form.message.value.trim(),
      company_website: form.company_website ? form.company_website.value : ''
    };

    try {
      const res = await fetch('/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const result = await res.json();

      if (result.success) {
        successEl.classList.remove('hidden');
        form.reset();
      } else {
        errorText.textContent = result.error || 'Something went wrong. Please try again.';
        errorEl.classList.remove('hidden');
      }
    } catch {
      errorText.textContent = 'Network error. Please try again or email directly.';
      errorEl.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btnText.textContent = 'Send Message';
      btnSpinner.classList.add('hidden');
    }
  });

  // FAQ accordion
  document.querySelectorAll('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const content = item.querySelector('.faq-content');
      const icon = item.querySelector('.faq-icon');
      const isOpen = !content.classList.contains('hidden');

      // Close all
      document.querySelectorAll('.faq-content').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(el => el.style.transform = '');

      if (!isOpen) {
        content.classList.remove('hidden');
        icon.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>

