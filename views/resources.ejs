<%- include('partials/head') %>
<%- include('partials/nav') %>

<main>

  <!-- ═══ HERO ════════════════════════════════════════════════════════════════ -->
  <section class="pt-32 pb-16 lg:pt-40 lg:pb-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl fade-in">
        <p class="text-xs font-semibold tracking-widest uppercase text-gold mb-6">Thinking &amp; Insights</p>
        <h1 class="font-serif text-5xl lg:text-6xl font-bold text-text-primary leading-tight mb-8">Resources &amp; Insights</h1>
        <p class="text-text-muted text-lg leading-relaxed">
          Practical thinking on leadership, career transitions, and executive presence — drawn from 25 years in the room and 500+ coaching conversations.
        </p>
      </div>
    </div>
  </section>

  <!-- GOLD RULE -->
  <div class="max-w-7xl mx-auto px-6 lg:px-8"><div class="gold-rule"></div></div>

  <!-- ═══ CATEGORY FILTER ═══════════════════════════════════════════════════ -->
  <% if (usedCategories.length > 0) { %>
  <section class="py-8 sticky top-20 bg-bg z-40 border-b border-border">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-2 flex-wrap">
        <a href="/resources"
          class="px-4 py-2 text-xs font-semibold tracking-wide rounded-full transition-all duration-200
            <%= activeCategory === 'all' ? 'bg-gray-900 text-white' : 'bg-white border border-border text-text-muted hover:border-gray-400' %>">
          All
        </a>
        <% usedCategories.forEach(function(cat) { %>
          <a href="/resources?category=<%= encodeURIComponent(cat) %>"
            class="px-4 py-2 text-xs font-semibold tracking-wide rounded-full transition-all duration-200
              <%= activeCategory === cat ? 'bg-gold text-white border border-gold' : 'bg-white border border-border text-text-muted hover:border-gold hover:text-gold' %>">
            <%= cat %>
          </a>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- ═══ ARTICLES GRID ═════════════════════════════════════════════════════ -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">

      <% if (articles.length === 0) { %>
        <div class="text-center py-24">
          <p class="text-text-muted text-lg mb-2">No articles in this category yet.</p>
          <a href="/resources" class="text-gold text-sm hover:underline">View all articles →</a>
        </div>
      <% } else { %>

        <!-- Featured first article (large) -->
        <% const featured = articles[0]; %>
        <article class="fade-in group mb-12 lg:mb-16">
          <a href="/blog/<%= featured.slug %>" class="grid grid-cols-1 lg:grid-cols-2 gap-0 border border-border rounded-2xl overflow-hidden hover:border-gold/50 transition-colors duration-300 bg-white shadow-sm hover:shadow-md">
            <div class="overflow-hidden aspect-[4/3] lg:aspect-auto">
              <% if (featured.featuredImage) { %>
                <img src="<%= featured.featuredImage %>"
                  alt="<%= featured.title %>"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
              <% } else { %>
                <div class="w-full h-full bg-gradient-to-br from-orange-50 to-amber-100 flex items-center justify-center">
                  <span class="text-gold text-6xl font-black opacity-20"><%= featured.category.charAt(0) %></span>
                </div>
              <% } %>
            </div>
            <div class="p-8 lg:p-12 flex flex-col justify-center">
              <div class="flex items-center gap-3 mb-5">
                <span class="px-3 py-1 bg-gold/10 border border-gold/30 text-gold text-xs font-semibold tracking-widest uppercase rounded-full"><%= featured.category %></span>
                <span class="text-xs text-text-muted"><%= featured.readTime %> min read</span>
              </div>
              <h2 class="font-serif text-2xl lg:text-3xl font-bold text-text-primary mb-4 leading-snug group-hover:text-gold transition-colors duration-300">
                <%= featured.title %>
              </h2>
              <p class="text-sm text-text-muted leading-relaxed mb-6"><%= featured.excerpt %></p>
              <div class="flex items-center gap-2 text-gold text-sm font-semibold">
                Read Article
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
              <p class="text-xs text-text-muted mt-4">
                <%= new Date(featured.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                &nbsp;·&nbsp; By <%= featured.author %>
              </p>
            </div>
          </a>
        </article>

        <!-- Remaining articles grid -->
        <% if (articles.length > 1) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          <% articles.slice(1).forEach(function(article) { %>
            <article class="fade-in group">
              <a href="/blog/<%= article.slug %>" class="block h-full border border-border rounded-2xl overflow-hidden bg-white hover:border-gold/50 transition-all duration-300 hover:shadow-md hover:-translate-y-1">
                <div class="overflow-hidden">
                  <div class="aspect-[4/3] overflow-hidden">
                    <% if (article.featuredImage) { %>
                      <img src="<%= article.featuredImage %>"
                        alt="<%= article.title %>"
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    <% } else { %>
                      <div class="w-full h-full bg-gradient-to-br from-orange-50 to-amber-100 flex items-center justify-center">
                        <span class="text-gold text-5xl font-black opacity-20"><%= article.category.charAt(0) %></span>
                      </div>
                    <% } %>
                  </div>
                </div>
                <div class="p-6">
                  <div class="flex items-center gap-3 mb-4">
                    <span class="px-2.5 py-1 bg-gold/10 border border-gold/30 text-gold text-xs font-semibold tracking-widest uppercase rounded-full"><%= article.category %></span>
                    <span class="text-xs text-text-muted"><%= article.readTime %> min read</span>
                  </div>
                  <h3 class="font-serif text-xl font-bold text-text-primary mb-3 leading-snug group-hover:text-gold transition-colors duration-300">
                    <%= article.title %>
                  </h3>
                  <p class="text-sm text-text-muted leading-relaxed mb-5 line-clamp-3"><%= article.excerpt %></p>
                  <div class="border-t border-border pt-4 flex items-center justify-between">
                    <p class="text-xs text-text-muted">
                      <%= new Date(article.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                    </p>
                    <span class="text-xs text-gold font-semibold flex items-center gap-1">
                      Read
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </span>
                  </div>
                </div>
              </a>
            </article>
          <% }); %>
        </div>
        <% } %>

      <% } %>
    </div>
  </section>

  <!-- GOLD RULE -->
  <div class="max-w-7xl mx-auto px-6 lg:px-8"><div class="gold-rule"></div></div>

  <!-- ═══ QUICK INSIGHTS ════════════════════════════════════════════════════ -->
  <section class="py-24 lg:py-32 bg-bg">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="fade-in mb-12">
        <p class="text-xs font-semibold tracking-widest uppercase text-gold mb-4">Quick Insights</p>
        <h2 class="font-serif text-3xl font-bold text-text-primary">Things worth knowing</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-0 border border-border rounded-2xl overflow-hidden">
        <div class="fade-in p-8 border-b md:border-r border-border hover:bg-gold/5 transition-colors duration-300">
          <p class="text-xs font-semibold tracking-widest uppercase text-gold mb-4">On Ownership</p>
          <p class="font-serif text-lg text-text-primary leading-relaxed">&ldquo;Leaders who wait for permission to lead are not ready to lead. Ownership isn't given. It's taken — thoughtfully, consistently, with full awareness of the consequences.&rdquo;</p>
        </div>
        <div class="fade-in p-8 border-b border-border hover:bg-gold/5 transition-colors duration-300">
          <p class="text-xs font-semibold tracking-widest uppercase text-gold mb-4">On Visibility</p>
          <p class="font-serif text-lg text-text-primary leading-relaxed">&ldquo;Being good at your job is not enough. The leaders who rise are the ones who make sure the right people know what they're good at — and why it matters to the organisation.&rdquo;</p>
        </div>
        <div class="fade-in p-8 md:border-r border-border hover:bg-gold/5 transition-colors duration-300">
          <p class="text-xs font-semibold tracking-widest uppercase text-gold mb-4">On Transformation</p>
          <p class="font-serif text-lg text-text-primary leading-relaxed">&ldquo;Real transformation is not dramatic. It's the quiet, persistent accumulation of better decisions — made by a leader who finally knows who they are and what they stand for.&rdquo;</p>
        </div>
        <div class="fade-in p-8 hover:bg-gold/5 transition-colors duration-300">
          <p class="text-xs font-semibold tracking-widest uppercase text-gold mb-4">On Feedback</p>
          <p class="font-serif text-lg text-text-primary leading-relaxed">&ldquo;The feedback most leaders need is rarely about skill. It's about courage — the courage to be direct, to be wrong, to be vulnerable, to hold the line when it's uncomfortable.&rdquo;</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BOOK CLARITY CALL ══════════════════════════════════════════════════ -->
  <section class="relative bg-dark-bg py-24 lg:py-32 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/bidisha-executive-coaching.png" alt="" class="w-full h-full object-cover object-center" aria-hidden="true" style="border-radius:0">
      <div class="absolute inset-0 bg-dark-bg/85"></div>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 lg:px-8 text-center fade-in">
      <p class="text-xs font-semibold tracking-widest uppercase text-gold mb-4">Ready to Begin?</p>
      <h2 class="font-serif text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">Book a Discovery Session</h2>
      <p class="text-gray-400 text-lg mb-10 max-w-xl mx-auto">
        The starting point for every coaching relationship. An honest, incisive conversation to understand exactly where you are, what's holding you back, and what's possible next.
      </p>
      <a href="https://topmate.io/bidisha_banerjee" target="_blank" rel="noopener noreferrer"
        class="inline-block px-10 py-4 bg-gold text-text-primary text-sm font-bold tracking-wide hover:bg-white transition-colors duration-300">
        Book Discovery Session
      </a>
      <p class="mt-5 text-xs text-gray-600">60 minutes &nbsp;·&nbsp; ₹12,000 &nbsp;·&nbsp; Redeemable against any programme</p>
    </div>
  </section>

</main>


<%- include('partials/footer') %>
