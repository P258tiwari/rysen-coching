<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login | RYSEN Coaching</title>
  <meta name="robots" content="noindex, nofollow">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            bg: '#F8F7F4',
            gold: '#F97316',
            'dark-bg': '#0D0D0D',
            border: '#E5E0D8'
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: Arial, Helvetica, sans-serif; }
    input:focus { outline: none; border-color: #F97316; }
  </style>
</head>
<body class="min-h-screen bg-bg flex items-center justify-center px-4">

  <div class="w-full max-w-sm">

    <!-- Brand -->
    <div class="text-center mb-10">
      <a href="/" class="inline-block text-2xl font-black tracking-[0.2em] text-gray-900 mb-2">RYSEN</a>
      <p class="text-xs text-gray-400 tracking-widest uppercase">Admin Panel</p>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-2xl shadow-lg p-8 border border-border">
      <h1 class="text-xl font-bold text-gray-900 mb-2">Sign in</h1>
      <p class="text-sm text-gray-400 mb-6">Enter your admin password to continue.</p>

      <% if (error) { %>
        <div class="mb-5 px-4 py-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-600">
          <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/admin/login">
        <div class="mb-5">
          <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wider mb-2" for="password">
            Password
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autofocus
            placeholder="Enter admin password"
            class="w-full px-4 py-3 border border-border rounded-xl text-sm bg-bg transition-colors duration-200"
          >
        </div>

        <button
          type="submit"
          class="w-full py-3 bg-gray-900 text-white text-sm font-semibold rounded-full hover:bg-gold transition-colors duration-300 tracking-wide"
        >
          Sign In
        </button>
      </form>
    </div>

    <p class="text-center mt-6 text-xs text-gray-400">
      <a href="/" class="hover:text-gold transition-colors">← Back to site</a>
    </p>

  </div>

</body>
</html>
