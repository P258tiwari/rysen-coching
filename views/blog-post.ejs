<%- include('partials/head') %>
<%- include('partials/nav') %>

<main>

  <!-- ═══ ARTICLE HEADER ═══════════════════════════════════════════════════ -->
  <section class="pt-32 pb-10 lg:pt-40 lg:pb-14">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-text-muted mb-8 fade-in" aria-label="Breadcrumb">
        <a href="/" class="hover:text-gold transition-colors">Home</a>
        <span>/</span>
        <a href="/resources" class="hover:text-gold transition-colors">Resources</a>
        <span>/</span>
        <a href="/resources?category=<%= encodeURIComponent(article.category) %>" class="hover:text-gold transition-colors"><%= article.category %></a>
      </nav>

      <!-- Category + read time -->
      <div class="flex items-center gap-3 mb-6 fade-in">
        <a href="/resources?category=<%= encodeURIComponent(article.category) %>"
          class="px-3 py-1 bg-gold/10 border border-gold/30 text-gold text-xs font-semibold tracking-widest uppercase rounded-full hover:bg-gold hover:text-white transition-colors">
          <%= article.category %>
        </a>
        <span class="text-xs text-text-muted"><%= article.readTime %> min read</span>
        <span class="text-text-muted text-xs">·</span>
        <span class="text-xs text-text-muted">
          <%= new Date(article.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %>
        </span>
      </div>

      <!-- Title -->
      <h1 class="font-serif text-4xl lg:text-5xl font-bold text-text-primary leading-tight mb-6 fade-in">
        <%= article.title %>
      </h1>

      <!-- Excerpt -->
      <% if (article.excerpt) { %>
        <p class="text-xl text-text-muted leading-relaxed mb-8 max-w-2xl fade-in"><%= article.excerpt %></p>
      <% } %>

      <!-- Author row -->
      <div class="flex items-center gap-4 pb-8 border-b border-border fade-in">
        <div class="w-10 h-10 rounded-full overflow-hidden bg-gray-200 flex-shrink-0">
          <img src="/images/bidisha-author-event.png" alt="Bidisha Banerjee" class="w-full h-full object-cover object-top">
        </div>
        <div>
          <p class="text-sm font-semibold text-text-primary">Bidisha Banerjee</p>
          <p class="text-xs text-text-muted">ICF PCC Coach · Author · Speaker</p>
        </div>
        <!-- Share -->
        <div class="ml-auto flex items-center gap-3">
          <button onclick="shareArticle()" class="flex items-center gap-1.5 text-xs text-text-muted hover:text-gold transition-colors" aria-label="Share article">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
            </svg>
            Share
          </button>
          <a href="https://www.linkedin.com/shareArticle?mini=true&url=<%= encodeURIComponent(canonicalUrl) %>&title=<%= encodeURIComponent(article.title) %>"
            target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-1.5 text-xs text-text-muted hover:text-[#0A66C2] transition-colors" aria-label="Share on LinkedIn">
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══ FEATURED IMAGE ════════════════════════════════════════════════════ -->
  <% if (article.featuredImage) { %>
  <section class="max-w-4xl mx-auto px-6 lg:px-8 mb-10">
    <div class="aspect-[16/7] rounded-2xl overflow-hidden">
      <img src="<%= article.featuredImage %>" alt="<%= article.title %>"
        class="w-full h-full object-cover">
    </div>
  </section>
  <% } %>

  <!-- ═══ ARTICLE BODY ══════════════════════════════════════════════════════ -->
  <section class="max-w-4xl mx-auto px-6 lg:px-8 pb-20 lg:pb-28">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">

      <!-- Main content -->
      <div class="lg:col-span-8">
        <div class="prose-rysen fade-in">
          <%- article.content %>
        </div>

        <!-- Tags / category -->
        <div class="mt-12 pt-8 border-t border-border">
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-xs text-text-muted font-semibold uppercase tracking-wider mr-2">Filed under:</span>
            <a href="/resources?category=<%= encodeURIComponent(article.category) %>"
              class="px-3 py-1 bg-gold/10 border border-gold/30 text-gold text-xs font-semibold rounded-full hover:bg-gold hover:text-white transition-colors">
              <%= article.category %>
            </a>
          </div>
        </div>

        <!-- Author bio card -->
        <div class="mt-10 p-6 lg:p-8 bg-white border border-border rounded-2xl">
          <div class="flex items-start gap-5">
            <div class="w-16 h-16 rounded-full overflow-hidden bg-gray-200 flex-shrink-0">
              <img src="/images/bidisha-author-event.png" alt="Bidisha Banerjee"
                class="w-full h-full object-cover object-top">
            </div>
            <div class="flex-1">
              <p class="font-bold text-text-primary mb-1">Bidisha Banerjee</p>
              <p class="text-xs text-text-muted mb-3">ICF PCC-Certified Executive Coach · Author · Keynote Speaker</p>
              <p class="text-sm text-text-muted leading-relaxed">
                With over 25 years as a global CHRO and CLO, Bidisha now coaches mid-senior leaders navigating career transitions, executive presence, and leadership identity. Founder of RYSEN Coaching.
              </p>
              <div class="flex items-center gap-3 mt-4">
                <a href="https://topmate.io/bidisha_banerjee" target="_blank" rel="noopener noreferrer"
                  class="px-4 py-2 bg-gray-900 text-white text-xs font-semibold rounded-full hover:bg-gold transition-colors">
                  Book a Session
                </a>
                <a href="https://www.linkedin.com/in/bidisha-banerjee" target="_blank" rel="noopener noreferrer"
                  class="px-4 py-2 border border-border text-text-muted text-xs font-semibold rounded-full hover:border-gold hover:text-gold transition-colors">
                  Follow on LinkedIn
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-4 hidden lg:block">
        <div class="sticky top-28 space-y-6">

          <!-- Table of contents (auto-built) -->
          <div class="p-5 bg-white border border-border rounded-2xl" id="toc-container">
            <p class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-3">In this article</p>
            <nav id="toc" class="space-y-1.5 text-sm text-text-muted"></nav>
          </div>

          <!-- CTA sidebar -->
          <div class="p-6 bg-gray-900 rounded-2xl text-center">
            <div class="w-8 h-0.5 bg-gold mx-auto mb-4"></div>
            <p class="text-white font-bold text-sm mb-2 leading-snug">Ready to break through?</p>
            <p class="text-gray-400 text-xs mb-4 leading-relaxed">Work 1-on-1 with Bidisha to move faster.</p>
            <a href="https://topmate.io/bidisha_banerjee" target="_blank" rel="noopener noreferrer"
              class="block w-full py-3 bg-gold text-white text-xs font-bold rounded-full hover:bg-orange-600 transition-colors">
              Book Discovery Session
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- ═══ RELATED ARTICLES ══════════════════════════════════════════════════ -->
  <% if (related.length > 0) { %>
  <section class="max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-28">
    <div class="gold-rule mb-12"></div>
    <div class="fade-in mb-10">
      <p class="text-xs font-semibold tracking-widest uppercase text-gold mb-3">Keep reading</p>
      <h2 class="font-serif text-3xl font-bold text-text-primary">More in <%= article.category %></h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% related.forEach(function(rel) { %>
        <article class="fade-in group">
          <a href="/blog/<%= rel.slug %>" class="block h-full border border-border rounded-2xl overflow-hidden bg-white hover:border-gold/50 transition-all duration-300 hover:shadow-md hover:-translate-y-1">
            <% if (rel.featuredImage) { %>
              <div class="aspect-[4/3] overflow-hidden">
                <img src="<%= rel.featuredImage %>" alt="<%= rel.title %>"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
              </div>
            <% } %>
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="px-2.5 py-1 bg-gold/10 border border-gold/30 text-gold text-xs font-semibold rounded-full"><%= rel.category %></span>
                <span class="text-xs text-text-muted"><%= rel.readTime %> min</span>
              </div>
              <h3 class="font-serif text-lg font-bold text-text-primary mb-2 leading-snug group-hover:text-gold transition-colors">
                <%= rel.title %>
              </h3>
              <p class="text-sm text-text-muted line-clamp-2"><%= rel.excerpt %></p>
            </div>
          </a>
        </article>
      <% }); %>
    </div>
  </section>
  <% } %>

  <!-- ═══ BOTTOM CTA ════════════════════════════════════════════════════════ -->
  <section class="bg-dark-bg py-24 lg:py-28">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center fade-in">
      <div class="w-10 h-0.5 bg-gold mx-auto mb-6"></div>
      <h2 class="font-serif text-3xl lg:text-4xl font-bold text-white mb-4 leading-tight">
        The next level won't wait — and neither should you.
      </h2>
      <p class="text-gray-400 mb-8 max-w-md mx-auto">Book a Discovery Session and find out exactly what's holding you back.</p>
      <a href="https://topmate.io/bidisha_banerjee" target="_blank" rel="noopener noreferrer"
        class="inline-block px-10 py-4 bg-gold text-white text-sm font-bold tracking-wide rounded-full hover:bg-orange-600 transition-colors duration-300">
        Book Your Discovery Session
      </a>
    </div>
  </section>

</main>

<script>
  // Auto-build table of contents from h2/h3 in article body
  (function() {
    const article = document.querySelector('.prose-rysen');
    const toc = document.getElementById('toc');
    const tocContainer = document.getElementById('toc-container');
    if (!article || !toc) return;

    const headings = article.querySelectorAll('h2, h3');
    if (headings.length < 2) { tocContainer.style.display = 'none'; return; }

    headings.forEach((h, i) => {
      const id = 'section-' + i;
      h.id = id;
      const a = document.createElement('a');
      a.href = '#' + id;
      a.textContent = h.textContent;
      a.className = 'block text-sm text-text-muted hover:text-gold transition-colors ' +
        (h.tagName === 'H3' ? 'pl-3 text-xs' : 'font-medium');
      toc.appendChild(a);
    });

    // Highlight active section
    const tocLinks = toc.querySelectorAll('a');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove('text-gold', 'font-semibold'));
          const active = toc.querySelector(`a[href="#${entry.target.id}"]`);
          if (active) active.classList.add('text-gold', 'font-semibold');
        }
      });
    }, { rootMargin: '-20% 0px -70% 0px' });

    headings.forEach(h => observer.observe(h));
  })();

  // Web Share API
  function shareArticle() {
    if (navigator.share) {
      navigator.share({
        title: document.title,
        url: window.location.href
      }).catch(() => {});
    } else {
      navigator.clipboard.writeText(window.location.href)
        .then(() => alert('Link copied to clipboard!'))
        .catch(() => {});
    }
  }
</script>

<%- include('partials/footer') %>
